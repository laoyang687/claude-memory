{"parentUuid":"e2b62b1c-5d90-428a-8e68-2eabbfc4ac90","isSidechain":false,"userType":"external","cwd":"D:\\yyc\\claude","sessionId":"e6f26847-7158-453b-af3d-80ab0f93489c","version":"2.1.59","gitBranch":"HEAD","slug":"rippling-foraging-hare","message":{"id":"msg_20260303200559ba84024633814070","type":"message","role":"assistant","model":"glm-4.7","content":[{"type":"tool_use","id":"call_e4baa232800448ffa5acf217","name":"Bash","input":{"command":"cd \"D:\\yyc\\claude\" && python -c \"\nfrom docx import Document\nfrom docx.shared import Pt, RGBColor, Inches\nfrom docx.enum.text import WD_ALIGN_PARAGRAPH\nfrom docx.oxml.ns import qn\nfrom docx.oxml import OxmlElement\n\ndef set_cell_background(cell, color):\n    '''设置单元格背景色'''\n    shading_elm = OxmlElement('w:shd')\n    shading_elm.set(qn('w:fill'), color)\n    cell._element.get_or_add_tcPr().append(shading_elm)\n\n# 创建新文档\ndoc = Document()\n\n# 设置页面边距\nsections = doc.sections\nfor section in sections:\n    section.top_margin = Inches(1)\n    section.bottom_margin = Inches(1)\n    section.left_margin = Inches(1.25)\n    section.right_margin = Inches(1.25)\n\n# 设置中文字体\ndoc.styles['Normal'].font.name = '宋体'\ndoc.styles['Normal']._element.rPr.rFonts.set(qn('w:eastAsia'), '宋体')\ndoc.styles['Normal'].font.size = Pt(12)\n\n# ============ 封面 ============\n# 封面标题\ntitle = doc.add_paragraph()\ntitle.alignment = WD_ALIGN_PARAGRAPH.CENTER\nrun = title.add_run('风电项目\\\\n复工复产专项方案')\nrun.font.size = Pt(22)\nrun.font.bold = True\nrun.font.name = '黑体'\nrun._element.rPr.rFonts.set(qn('w:eastAsia'), '黑体')\n\n# 封面分隔线\nfor _ in range(3):\n    doc.add_paragraph()\n\n# 封面信息表格\ninfo_table = doc.add_table(rows=6, cols=2)\ninfo_table.style = 'Table Grid'\ninfo_table.alignment = WD_ALIGN_PARAGRAPH.CENTER\n\n# 设置表格宽度\nfor row in info_table.rows:\n    row.height = Inches(0.4)\n\ncells_data = [\n    ('项目名称', '神池县磨石山、义井100MW风电项目（二期）'),\n    ('编制单位', '山西晋开电力科技有限公司'),\n    ('编制日期', '2026年3月3日'),\n    ('版本', 'A/1.0'),\n    ('', ''),\n    ('', '')\n]\n\nfor i, (label, value) in enumerate(cells_data):\n    cell = info_table.rows[i].cells[0]\n    cell.text = label\n    cell.paragraphs[0].alignment = WD_ALIGN_PARAGRAPH.CENTER\n    cell.paragraphs[0].runs[0].font.bold = True\n    cell.paragraphs[0].runs[0].font.size = Pt(14)\n    \n    cell = info_table.rows[i].cells[1]\n    cell.text = value\n    cell.paragraphs[0].alignment = WD_ALIGN_PARAGRAPH.CENTER\n    cell.paragraphs[0].runs[0].font.size = Pt(14)\n\ndoc.add_page_break()\n\n# ============ 目录 ============\ndoc.add_heading('目录', level=1)\ntoc_items = [\n    '第一部分  复工复产专项方案',\n    '  第一章  工程概况',\n    '  第二章  编制依据',\n    '  第三章  复工准备',\n    '  第四章  组织机构',\n    '  第五章  复工计划',\n    '  第六章  资源配置',\n    '  第七章  安全保障措施',\n    '  第八章  质量保障措施',\n    '  第九章  应急管理',\n    '  第十章  复工验收程序',\n    '第二部分  风机调试计划',\n    '第三部分  电装进度计划表',\n    '第四部分  相关管理表格'\n]\n\nfor item in toc_items:\n    p = doc.add_paragraph()\n    p.paragraph_format.left_indent = Inches(0.25 if item.startswith('  ') else 0)\n    run = p.add_run(item)\n    run.font.size = Pt(12)\n\ndoc.add_page_break()\n\n# ============ 第一部分 复工复产专项方案 ============\ndoc.add_heading('第一部分  复工复产专项方案', level=1)\n\n# ========== 第一章 工程概况 ==========\ndoc.add_heading('第一章  工程概况', level=2)\n\ndoc.add_heading('一、项目基本情况', level=3)\np = doc.add_paragraph()\np.add_run('项目名称：').bold = True\np.add_run('神池县磨石山、义井100MW风电项目（二期）\\\\n')\np.add_run('建设地点：').bold = True\np.add_run('山西省忻州市神池县\\\\n')\np.add_run('建设单位：').bold = True\np.add_run('XXX新能源有限公司\\\\n')\np.add_run('总承包单位（EPC）：').bold = True\np.add_run('山西晋开电力科技有限公司\\\\n')\np.add_run('监理单位：').bold = True\np.add_run('XXX工程监理有限公司\\\\n')\np.add_run('设计单位：').bold = True\np.add_run('XXX电力设计院\\\\n')\n\ndoc.add_heading('二、工程规模及建设内容', level=3)\ndoc.add_paragraph('本期工程装机容量100MW，安装20台单机容量5.0MW的风力发电机组，配套建设110kV升压站1座，集电线路35km，检修道路25km。')\n\ndoc.add_heading('三、当前工程进展情况', level=3)\ndoc.add_paragraph('本项目于2024年5月开工建设，截至目前已完成以下工作内容：')\ndoc.add_paragraph('1. 风机基础：20台风机基础全部完成；')\ndoc.add_paragraph('2. 风机吊装：20台塔筒、机舱、叶片吊装全部完成；')\ndoc.add_paragraph('3. 升压站：土建工程完成，电气设备安装完成，并网投产；')\ndoc.add_paragraph('4. 集电线路：地埋敷设完成，终端头制作完成；')\ndoc.add_paragraph('5. 已投产风机：8台风机已完成调试并发电，运行正常。')\n\ndoc.add_heading('四、剩余工作内容', level=3)\ndoc.add_paragraph('1. 风机电气安装：12台未调试风机（F09-F20）的电气接线及检查；')\ndoc.add_paragraph('2. 风机调试：12台风机的静态调试、动态调试及并网调试；')\ndoc.add_paragraph('3. 全场联调：全场风机联合运行调试；')\ndoc.add_paragraph('4. 竣工资料：竣工图纸、资料的整理归档。')\n\ndoc.add_heading('五、春节停工情况', level=3)\ndoc.add_paragraph('本项目于2025年1月20日进入春节假期停工，停工期间安排了值班人员进行现场看护，设备及设施封存完好，未发生安全事件。')\n\n# ========== 第二章 编制依据 ==========\ndoc.add_heading('第二章  编制依据', level=2)\n\ndoc.add_heading('一、法律法规', level=3)\ndoc.add_paragraph('1. 《中华人民共和国安全生产法》（2021年修订版）')\ndoc.add_paragraph('2. 《建设工程安全生产管理条例》（国务院令第393号）')\ndoc.add_paragraph('3. 《电力建设工程施工安全监督管理办法》（发改委令第28号）')\ndoc.add_paragraph('4. 《生产经营单位安全培训规定》（安监总局令第3号）')\n\ndoc.add_heading('二、标准规范', level=3)\ndoc.add_paragraph('1. 《风力发电工程施工与验收规范》（GB/T 5XXXX-20XX）')\ndoc.add_paragraph('2. 《电力建设安全工作规程 第2部分：电力线路》（DL 5009.2）')\ndoc.add_paragraph('3. 《电力建设安全工作规程 第3部分：变电站》（DL 5009.3）')\ndoc.add_paragraph('4. 《建筑施工高处作业安全技术规范》（JGJ 80-2016）')\ndoc.add_paragraph('5. 《施工现场临时用电安全技术规范》（JGJ 46-2005）')\ndoc.add_paragraph('6. 《起重机械安全规程》（GB 6067-2010）')\n\ndoc.add_heading('三、项目文件', level=3)\ndoc.add_paragraph('1. EPC总承包合同及招投标文件；')\ndoc.add_paragraph('2. 施工组织设计及专项施工方案；')\ndoc.add_paragraph('3. 风机厂家技术说明书及调试手册；')\ndoc.add_paragraph('4. 设计图纸、变更单及技术交底文件；')\ndoc.add_paragraph('5. 监理单位及建设单位相关管理要求。')\n\n# ========== 第三章 复工准备 ==========\ndoc.add_heading('第三章  复工准备', level=2)\n\ndoc.add_heading('一、人员准备', level=3)\ndoc.add_paragraph('（一）管理人员到岗')\ntable = doc.add_table(rows=6, cols=3)\ntable.style = 'Table Grid'\nheader = table.rows[0].cells\nheader[0].text = '序号'\nheader[1].text = '职务'\nheader[2].text = '到岗情况'\n\ndata = [\n    ['1', '项目经理', '已到岗'],\n    ['2', '项目总工程师', '已到岗'],\n    ['3', '安全总监', '已到岗'],\n    ['4', '施工经理', '已到岗'],\n    ['5', '各部门负责人', '已到岗'],\n]\n\nfor i, row_data in enumerate(data, 1):\n    cells = table.rows[i].cells\n    for j, val in enumerate(row_data):\n        cells[j].text = val\n\ndoc.add_paragraph('\\\\n（二）施工人员组织')\ndoc.add_paragraph('1. 施工班组人员已于2月25日开始陆续返场，进行实名制登记；')\ndoc.add_paragraph('2. 特种作业人员（电工、焊工、起重工、高处作业人员等）证件核查齐全有效；')\ndoc.add_paragraph('3. 新进场人员已完成三级安全教育培训；')\ndoc.add_paragraph('4. 全体返场人员进行复工安全教育培训并考核合格。')\n\ndoc.add_heading('二、技术准备', level=3)\ndoc.add_paragraph('1. 复工前组织图纸会审，核对设计与现场实际情况；')\ndoc.add_paragraph('2. 编制专项施工方案（调试方案、电气安装方案）并报审；')\ndoc.add_paragraph('3. 对施工班组进行详细的技术交底和安全交底；')\ndoc.add_paragraph('4. 检查施工机械设备的技术状况，确保完好；')\ndoc.add_paragraph('5. 准备齐全的检验检测仪器设备并校验有效。')\n\ndoc.add_heading('三、现场准备', level=3)\ndoc.add_paragraph('（一）安全检查')\ndoc.add_paragraph('1. 对施工现场进行全面安全检查，形成检查记录；')\ndoc.add_paragraph('2. 检查脚手架、爬梯、平台等设施的安全性能；')\ndoc.add_paragraph('3. 检查起重机械、吊装索具的完好性；')\ndoc.add_paragraph('4. 检查临时用电设施，确保用电安全；')\ndoc.add_paragraph('5. 清理现场积雪、积冰，确保作业面及通道安全；')\ndoc.add_paragraph('6. 检查消防设施配置情况，确保消防器材齐全有效。')\n\ndoc.add_paragraph('\\\\n（二）设备检查')\ndoc.add_paragraph('1. 检查已投运8台风机运行情况，记录运行参数；')\ndoc.add_paragraph('2. 检查未调试风机（F09-F20）的设备状态；')\ndoc.add_paragraph('3. 检查箱变、集电线路运行状态；')\ndoc.add_paragraph('4. 检查升压站设备运行情况。')\n\ndoc.add_heading('四、物资准备', level=3)\ndoc.add_paragraph('1. 盘点剩余工程材料（电缆、接线端子、接地材料等），制定采购计划；')\ndoc.add_paragraph('2. 检查安全防护用品（安全帽、安全带、安全网、绝缘鞋等）的库存及质量；')\ndoc.add_paragraph('3. 检查检测仪器（绝缘电阻测试仪、继电保护测试仪等）的有效性；')\ndoc.add_paragraph('4. 准备应急物资及救援设备。')\n\n# ========== 第四章 组织机构 ==========\ndoc.add_heading('第四章  组织机构', level=2)\n\ndoc.add_heading('一、复工领导小组', level=3)\ndoc.add_paragraph('为确保复工复产工作有序推进，成立复工领导小组：')\n\ntable = doc.add_table(rows=8, cols=3)\ntable.style = 'Table Grid'\nheader = table.rows[0].cells\nheader[0].text = '职务'\nheader[1].text = '姓名'\nheader[2].text = '职责'\n\ndata = [\n    ['组长', 'XXX', '全面负责复工工作，审批复工计划'],\n    ['副组长', 'XXX', '负责技术管理、方案编制'],\n    ['副组长', 'XXX', '负责安全管理、教育培训'],\n    ['成员', 'XXX', '负责施工组织、进度控制'],\n    ['成员', 'XXX', '负责质量检查、验收工作'],\n    ['成员', 'XXX', '负责设备管理、调试工作'],\n    ['成员', 'XXX', '负责物资保障、材料供应'],\n]\n\nfor i, row_data in enu