10风机动态调试及并网。')\n\ndoc.add_heading('三、总体进度目标', level=3)\ntable = doc.add_table(rows=5, cols=2)\ntable.style = 'Table Grid'\ndata = [\n    ['3月15日前', '完成F09-F12风机电气安装'],\n    ['3月31日前', '完成F09-F20风机电气安装'],\n    ['4月15日前', '完成剩余12台风机调试并网'],\n    ['4月30日前', '完成全场联调及专项验收准备'],\n]\n\nfor i, row_data in enumerate(data):\n    cells = table.rows[i].cells\n    for j, val in enumerate(row_data):\n        cells[j].text = val\n\ndoc.add_heading('四、进度控制措施', level=3)\ndoc.add_paragraph('1. 实行周计划管理，每周召开进度协调会；')\ndoc.add_paragraph('2. 建立进度日报制度，及时掌握现场进展；')\ndoc.add_paragraph('3. 实行关键节点考核，确保节点目标实现；')\ndoc.add_paragraph('4. 加强与厂家、监理、业主的沟通协调；')\ndoc.add_paragraph('5. 预判天气影响，合理安排施工计划。')\n\n# ========== 第六章 资源配置 ==========\ndoc.add_heading('第六章  资源配置', level=2)\n\ndoc.add_heading('一、人力资源配置', level=3)\ndoc.add_paragraph('（一）管理人员')\ntable = doc.add_table(rows=9, cols=3)\ntable.style = 'Table Grid'\nheader = table.rows[0].cells\nheader[0].text = '岗位'\nheader[1].text = '人数'\nheader[2].text = '备注'\n\ndata = [\n    ['项目经理', '1', '全面负责'],\n    ['项目总工程师', '1', '技术负责'],\n    ['安全总监', '1', '安全负责'],\n    ['施工经理', '2', '现场施工'],\n    ['电气工程师', '2', '电气技术'],\n    ['调试工程师', '2', '风机调试'],\n    ['质量工程师', '1', '质量检查'],\n    ['安全员', '3', '安全监督'],\n]\n\nfor i, row_data in enumerate(data, 1):\n    cells = table.rows[i].cells\n    for j, val in enumerate(row_data):\n        cells[j].text = val\n\ndoc.add_paragraph('\\\\n（二）施工班组人员')\ndoc.add_paragraph('电工班：16人（分2个班组，每班8人）')\ndoc.add_paragraph('起重班：4人（持证上岗）')\ndoc.add_paragraph('试验班：6人（含厂家技术人员2人）')\ndoc.add_paragraph('合计：施工人员26人，管理人员13人，总计39人')\n\ndoc.add_heading('二、主要施工机械配置', level=3)\ntable = doc.add_table(rows=8, cols=3)\ntable.style = 'Table Grid'\nheader = table.rows[0].cells\nheader[0].text = '设备名称'\nheader[1].text = '规格型号'\nheader[2].text = '数量'\n\ndata = [\n    ['汽车吊', '80t', '1台'],\n    ['电缆敷设机', 'JY-500', '2台'],\n    ['液压压接机', 'YQ-300', '2台'],\n    ['绝缘电阻测试仪', '5000V', '2台'],\n    ['继电保护测试仪', 'PW336', '1套'],\n    ['对讲机', 'GP328D', '10部'],\n    ['笔记本电脑',