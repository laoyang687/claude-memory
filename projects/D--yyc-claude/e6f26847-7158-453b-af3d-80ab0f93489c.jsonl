{"parentUuid":"12ff6816-e1f5-4cd6-8524-e704d0913bb0","isSidechain":false,"userType":"external","cwd":"D:\\yyc\\claude","sessionId":"e6f26847-7158-453b-af3d-80ab0f93489c","version":"2.1.59","gitBranch":"HEAD","slug":"rippling-foraging-hare","type":"user","message":{"role":"user","content":[{"tool_use_id":"call_e8f8aa2da39b420a9e47f930","type":"tool_result","content":"The file D:\\yyc\\claude\\generate_doc_v2.py has been updated successfully."}]},"uuid":"5d1628a6-2bcd-4d88-bf05-91f5328ee8e4","timestamp":"2026-03-03T16:26:59.434Z","toolUseResult":{"filePath":"D:\\yyc\\claude\\generate_doc_v2.py","oldString":"for i, (label, value) in enumerate(info_data):\n    row = info_table.rows[i]\n    row.cells[0].text = label\n    row.cells[0].paragraphs[0].runs[0].font.bold = True\n    row.cells[1].text = value\n    for cell in row.cells:\n        for para in cell.paragraphs:\n            para.alignment = WD_ALIGN_PARAGRAPH.CENTER\n            for run in para.runs:\n                run.font.size = Pt(12)\n\ndoc.add_page_break()","newString":"for i, (label, value) in enumerate(info_data):\n    row = info_table.rows[i]\n    row.cells[0].text = label\n    row.cells[0].paragraphs[0].runs[0].font.bold = True\n    row.cells[1].text = value\n    for cell in row.cells:\n        for para in cell.paragraphs:\n            para.alignment = WD_ALIGN_PARAGRAPH.CENTER\n            for run in para.runs:\n                run.font.size = Pt(12)\n\n# 添加一些空行\nfor _ in range(4):\n    doc.add_paragraph()\n\n# 签字栏表格\nsign_table = doc.add_table(rows=5, cols=4)\nsign_table.style = 'Table Grid'\n\n# 设置表头\nheader_cells = sign_table.rows[0].cells\nheader_cells[0].text = '编制人'\nheader_cells[1].text = '审批人'\nheader_cells[2].text = '监理总监'\nheader_cells[3].text = '业主代表'\n\n# 设置签字栏\nfor i in range(4):\n    # 第一行：标题和空白\n    cell = sign_table.rows[1].cells[i]\n    if i == 0:\n        cell.text = '签字：        日期：'\n    elif i == 1:\n        cell.text = '签字：        日期：'\n    elif i == 2:\n        cell.text = '签字：        日期：'\n    else:\n        cell.text = '签字：        日期：'\n\n# 合并第2-4行的单元格形成签字空白区\nfor i in range(4):\n    cell = sign_table.rows[2].cells[i]\n    cell.text = ''\n    cell = sign_table.rows[3].cells[i]\n    cell.text = ''\n    cell = sign_table.rows[4].cells[i]\n    cell.text = ''\n\n# 设置签字栏格式\nfor row in sign_table.rows:\n    for cell in row.cells:\n        for para in cell.paragraphs:\n            para.alignment = WD_ALIGN_PARAGRAPH.CENTER\n            for run in para.runs:\n                run.font.size = Pt(11)\n\ndoc.add_page_break()","originalFile":"# -*- coding: utf-8 -*-\nfrom docx import Document\nfrom docx.shared import Pt, Inches, RGBColor\nfrom docx.enum.text import WD_ALIGN_PARAGRAPH\nfrom docx.oxml.ns import qn\nfrom docx.oxml import OxmlElement\n\ndef set_cell_background(cell, color_value):\n    \"\"\"设置单元格背景色\"\"\"\n    shading_elm = OxmlElement('w:shd')\n    shading_elm.set(qn('w:fill'), color_value)\n    cell._element.get_or_add_tcPr().append(shading_elm)\n\n# 创建文档\ndoc = Document()\n\n# 设置页面\nfor section in doc.sections:\n    section.top_margin = Inches(1)\n    section.bottom_margin = Inches(1)\n    section.left_margin = Inches(1.25)\n    section.right_margin = Inches(1.25)\n\n# 设置字体\ndoc.styles['Normal'].font.name = '宋体'\ndoc.styles['Normal']._element.rPr.rFonts.set(qn('w:eastAsia'), '宋体')\ndoc.styles['Normal'].font.size = Pt(12)\n\n# ============ 封面 ============\ntitle = doc.add_paragraph()\ntitle.alignment = WD_ALIGN_PARAGRAPH.CENTER\nrun = title.add_run('100MW风电项目\\n复工复产专项方案')\nrun.font.size = Pt(22)\nrun.font.bold = True\nrun.font.color.rgb = RGBColor(0, 51, 102)\n\nfor _ in range(3):\n    doc.add_paragraph()\n\n# 封面信息\ninfo_data = [\n    ('项目名称', '神池县磨石山、义井100MW风电项目（二期）'),\n    ('编制单位', '山西晋开电力科技有限公司'),\n    ('编制日期', '2026年3月3日'),\n    ('版本', 'A/2.0  修订版'),\n]\n\ninfo_table = doc.add_table(rows=len(info_data), cols=2)\ninfo_table.style = 'Table Grid'\n\nfor i, (label, value) in enumerate(info_data):\n    row = info_table.rows[i]\n    row.cells[0].text = label\n    row.cells[0].paragraphs[0].runs[0].font.bold = True\n    row.cells[1].text = value\n    for cell in row.cells:\n        for para in cell.paragraphs:\n            para.alignment = WD_ALIGN_PARAGRAPH.CENTER\n            for run in para.runs:\n                run.font.size = Pt(12)\n\ndoc.add_page_break()\n\n# ============ 目录 ============\ndoc.add_heading('目录', level=1)\n\ntoc_items = [\n    '第一章  项目概况与当前状态分析',\n    '第二章  复工组织架构与安全管控',\n    '第三章  35kV集电线路铁塔施工专项方案',\n    '第四章  风机电装及调试计划',\n    '第五章  涉网实验专项方案',\n    '第六章  风机消缺与闭环管理',\n    '第七章  沉降观测专项方案',\n    '第八章  环境保护与水保恢复方案',\n    '第九章  环保应急预案',\n    '第十章  复工验收程序',\n    '附件1  剩余工程复工进度计划表',\n    '附件2  全场沉降观测记录明细表',\n    '附件3  风机消缺闭环跟踪表',\n    '附件4  环境水保恢复及应急响应单',\n    '附件5  每日作业许可及安全交底记录',\n]\n\nfor item in toc_items:\n    p = doc.add_paragraph()\n    p.paragraph_format.left_indent = Inches(0.25)\n    run = p.add_run(item)\n    run.font.size = Pt(12)\n\ndoc.add_page_break()\n\n# ============ 第一章 ============\ndoc.add_heading('第一章  项目概况与当前状态分析', level=1)\n\ndoc.add_heading('一、项目基本情况', level=2)\np = doc.add_paragraph()\np.add_run('项目名称：').bold = True\np.add_run('神池县磨石山、义井100MW风电项目（二期）\\n')\np.add_run('建设地点：').bold = True\np.add_run('山西省忻州市神池县\\n')\np.add_run('装机容量：').bold = True\np.add_run('100MW（13台单机容量7.7MW风电机组）\\n')\np.add_run('建设单位：').bold = True\np.add_run('XXX新能源有限公司\\n')\np.add_run('总承包单位（EPC）：').bold = True\np.add_run('山西晋开电力科技有限公司\\n')\n\ndoc.add_heading('二、当前工程状态', level=2)\n\ndoc.add_heading('（一）已完成工作', level=3)\ndoc.add_paragraph('1. 风机吊装：13台风机基础及塔筒、机舱、叶片吊装全部完成；')\ndoc.add_paragraph('2. 升压站：110kV升压站土建及电气设备安装完成，受电完成；')\ndoc.add_paragraph('3. 集电线路：35kV集电线路主体施工完成，冲击试验及箱变投运完成；')\ndoc.add_paragraph('4. 并网发电：8台风机已完成并网调试并发电，运行稳定。')\n\ndoc.add_heading('（二）待开展核心工作', level=3)\ndoc.add_paragraph('1. 电装工程：剩余5台机组塔筒及机舱内电装；')\ndoc.add_paragraph('2. 线路施工：4基35kV集电线路铁塔组立及架线施工；')\ndoc.add_paragraph('3. 调试试验：5台机组单机调试、全站涉网实验；')\ndoc.add_paragraph('4. 消缺工作：全场13台风机缺陷排查与处理；')\ndoc.add_paragraph('5. 环境治理：风机平台整治、环保水保恢复；')\ndoc.add_paragraph('6. 监测工作：全场建（构）筑物沉降观测。')\n\ndoc.add_heading('三、春节停工及复工情况', level=2)\ndoc.add_paragraph('本项目于2025年1月20日进入春节假期停工，停工期间安排值班人员进行现场看护，设备及设施封存完好，未发生安全事件。现计划于2026年3月初全面复工。')\n\n# ============ 第二章 ============\ndoc.add_heading('第二章  复工组织架构与安全管控', level=1)\n\ndoc.add_heading('一、复工领导小组', level=2)\ntable = doc.add_table(rows=8, cols=3)\ntable.style = 'Table Grid'\nheader = table.rows[0].cells\nheader[0].text = '职务'\nheader[1].text = '姓名'\nheader[2].text = '职责'\n\ndata = [\n    ['组长', 'XXX', '全面负责复工工作，审批复工计划'],\n    ['副组长', 'XXX', '负责技术管理、方案编制'],\n    ['副组长', 'XXX', '负责安全管理、教育培训'],\n    ['成员', 'XXX', '负责线路施工管理'],\n    ['成员', 'XXX', '负责电装及调试管理'],\n    ['成员', 'XXX', '负责环保水保管理'],\n    ['成员', 'XXX', '负责物资保障'],\n]\n\nfor i, row_data in enumerate(data, 1):\n    cells = table.rows[i].cells\n    for j, val in enumerate(row_data):\n        cells[j].text = val\n\ndoc.add_heading('二、安全管控措施', level=2)\n\ndoc.add_heading('（一）\"双重授权\"管理制度', level=3)\ndoc.add_paragraph('针对\"部分发电、部分施工\"的高风险状态，实行严格的分区管理：')\n\ntable = doc.add_table(rows=3, cols=3)\ntable.style = 'Table Grid'\nheader = table.rows[0].cells\nheader[0].text = '区域类型'\nheader[1].text = '范围'\nheader[2].text = '管控要求'\n\ndata = [\n    ['运行区', '已发电8台机组相关设备、35kV带电线路、升压站', '办理第一种工作票，严格执行\"两票三制\"'],\n    ['施工区', '剩余5台机组、4基铁塔施工区域、平台整治区域', '办理第二种工作票，强化现场监护'],\n]\n\nfor i, row_data in enumerate(data, 1):\n    cells = table.rows[i].cells\n    for j, val in enumerate(row_data):\n        cells[j].text = val\n\ndoc.add_heading('（二）高风险作业管控', level=3)\ndoc.add_paragraph('1. 邻近带电体作业：严格执行安全距离要求，设置专职监护人；')\ndoc.add_paragraph('2. 高处作业：2m以上必须系挂安全带，恶劣天气禁止作业；')\ndoc.add_paragraph('3. 起重作业：严格执行\"十不吊\"规定，风力超过5级禁止吊装；')\ndoc.add_paragraph('4. 临时用电：严格执行\"一机一闸一漏一箱\"制度。')\n\ndoc.add_heading('（三）复工安全培训', level=3)\ndoc.add_paragraph('1. 管理人员：组织安全规程学习，考试合格后方可上岗；')\ndoc.add_paragraph('2. 施工人员：进行复工安全教育，重点讲解邻近带电体作业安全要求；')\ndoc.add_paragraph('3. 特种作业人员：核查证件有效性，进行专项技术交底。')\n\n# ============ 第三章 ============\ndoc.add_heading('第三章  35kV集电线路铁塔施工专项方案', level=1)\n\ndoc.add_heading('一、工程概况', level=2)\ndoc.add_paragraph('剩余4基35kV集电线路铁塔组立及架线施工，位于已带电运行线路末端。')\n\ndoc.add_heading('二、施工工序', level=2)\ndoc.add_paragraph('1. 基础复核：对已完工铁塔基础进行复核测量；')\ndoc.add_paragraph('2. 塔材运输：利用检修道路进行塔材分段运输到位；')\ndoc.add_paragraph('3. 组塔施工：采用吊车组立方式，分段吊装；')\ndoc.add_paragraph('4. 挂线施工：导地线展放、紧线、附件安装；')\ndoc.add_paragraph('5. 接地施工：接地电阻测试及整改。')\n\ndoc.add_heading('三、安全控制要点', level=2)\ndoc.add_heading('（一）邻近带电体作业防护', level=3)\ndoc.add_paragraph('1. 与已带电线路保持足够安全距离（110kV：1.5m，35kV：1.0m）；')\ndoc.add_paragraph('2. 施工前申请停运相邻线路，确需带电施工时制定专项方案；')\ndoc.add_paragraph('3. 设置专职监护人，配备合格的验电器、绝缘杆。')\n\ndoc.add_heading('（二）防感应电措施', level=3)\ndoc.add_paragraph('1. 施工作业人员穿戴绝缘防护用品；')\ndoc.add_paragraph('2. 塔材接地线连接可靠；')\ndoc.add_paragraph('3. 雷雨天气严禁作业。')\n\ndoc.add_heading('（三）跨越施工专项措施', level=3)\ndoc.add_paragraph('1. 编制专项跨越施工方案并报审；')\ndoc.add_paragraph('2. 搭设跨越架时保持与被跨越物的安全距离；')\ndoc.add_paragraph('3. 设置封网装置，防止落物损伤带电设备。')\n\ndoc.add_heading('四、进度计划', level=2)\ndoc.add_paragraph('计划工期：2026年3月5日 - 2026年3月15日（共11天）')\n\n# ============ 第四章 ============\ndoc.add_heading('第四章  风机电装及调试计划', level=1)\n\ndoc.add_heading('一、电装工程', level=2)\ndoc.add_paragraph('剩余5台机组（F09-F13）塔筒及机舱内电装工作。')\n\ndoc.add_heading('（一）电装内容', level=3)\ndoc.add_paragraph('1. 塔筒内电气设备安装：照明、通风、加热器；')\ndoc.add_paragraph('2. 机舱内电气接线：主控柜、变桨柜、传感器；')\ndoc.add_paragraph('3. 1140V电缆敷设及终端头制作；')\ndoc.add_paragraph('4. 低压配电系统接线；')\ndoc.add_paragraph('5. 通讯光缆敷设及熔接。')\n\ndoc.add_heading('（二）质量控制要点', level=3)\ndoc.add_paragraph('1. 电缆敷设：固定牢固、标识清晰、弯曲半径符合规范；')\ndoc.add_paragraph('2. 电缆终端：力矩紧固、绝缘测试合格；')\ndoc.add_paragraph('3. 接线工艺：压接可靠、标识正确、屏蔽层接地规范。')\n\ndoc.add_heading('二、单机调试', level=2)\n\ndoc.add_heading('（一）静态调试', level=3)\ndoc.add_paragraph('1. 外观检查：设备完好、螺栓紧固、标识齐全；')\ndoc.add_paragraph('2. 电气检查：接线正确、绝缘合格、接地可靠；')\ndoc.add_paragraph('3. 控制系统：参数设置正确、通讯正常；')\ndoc.add_paragraph('4. 机械系统：齿轮箱油位、制动器间隙、对中情况。')\n\ndoc.add_heading('（二）动态调试', level=3)\ndoc.add_paragraph('1. 启动试验：手动/自动启动、启动电流正常；')\ndoc.add_paragraph('2. 运行试验：各工况运行参数正常；')\ndoc.add_paragraph('3. 保护试验：超速、振动、温度等保护动作正确。')\n\n# ============ 第五章 ============\ndoc.add_heading('第五章  涉网实验专项方案', level=1)\n\ndoc.add_heading('一、实验目的', level=2)\ndoc.add_paragraph('验证风电机组及风电场涉网性能满足电网调度要求，取得并网调度协议所需的试验报告。')\n\ndoc.add_heading('二、实验项目及内容', level=2)\n\ntable = doc.add_table(rows=6, cols=3)\ntable.style = 'Table Grid'\nheader = table.rows[0].cells\nheader[0].text = '序号'\nheader[1].text = '实验项目'\nheader[2].text = '实验内容'\n\ndata = [\n    ['1', '电能质量测试', '谐波、电压波动与闪变、间谐波检测'],\n    ['2', '有功/无功控制测试', 'AGC/AVC系统联调，功率调节精度测试'],\n    ['3', '高低电压穿越验证', 'LVRT/HVRT功能验证，故障穿越能力测试'],\n    ['4', '一次调频实验', '转速死区测试、调频特性测试、响应时间测试'],\n    ['5', '电网适应性测试', '频率/电压偏差运行能力测试'],\n]\n\nfor i, row_data in enumerate(data, 1):\n    cells = table.rows[i].cells\n    for j, val in enumerate(row_data):\n        cells[j].text = val\n\ndoc.add_heading('三、实验组织', level=2)\ndoc.add_paragraph('1. 委托有资质的第三方检测机构承担；')\ndoc.add_paragraph('2. 提前向电网调度部门申请实验窗口；')\ndoc.add_paragraph('3. 准备检测设备、测试仪器及通讯保障；')\ndoc.add_paragraph('4. 组织厂家、调试、运行人员配合实验。')\n\ndoc.add_heading('四、进度安排', level=2)\ndoc.add_paragraph('计划时间：2026年3月20日 - 2026年4月5日（具体时间需与调度确认）')\n\n# ============ 第六章 ============\ndoc.add_heading('第六章  风机消缺与闭环管理', level=1)\n\ndoc.add_heading('一、消缺工作范围', level=2)\ndoc.add_paragraph('对全场13台风机进行全面排查，针对运行中暴露的问题进行整改。')\n\ndoc.add_heading('二、重点消缺内容', level=2)\n\ntable = doc.add_table(rows=6, cols=3)\ntable.style = 'Table Grid'\nheader = table.rows[0].cells\nheader[0].text = '类别'\nheader[1].text = '消缺内容'\nheader[2].text = '处理措施'\n\ndata = [\n    ['螺栓紧固', '叶片、塔筒连接螺栓力矩抽检', '按厂家要求进行力矩复核并标识'],\n    ['渗漏处理', '偏航/变桨减速机、液压站渗油', '更换密封件、清洁管路、补油'],\n    ['系统报警', '传感器误报、通讯故障', '检查屏蔽层、更换传感器、优化参数'],\n    ['电缆发热', '1140V大电缆终端头', '检查力矩、红外测温、必要时重做终端头'],\n    ['平台缺陷', '排水沟淤积、护坡损坏', '清理疏通、加固护坡'],\n]\n\nfor i, row_data in enumerate(data, 1):\n    cells = table.rows[i].cells\n    for j, val in enumerate(row_data):\n        cells[j].text = val\n\ndoc.add_heading('三、消缺管理流程', level=2)\ndoc.add_paragraph('1. 缺陷发现：运行巡视、检修发现、厂家反馈；')\ndoc.add_paragraph('2. 缺陷登记：填写消缺单，明确缺陷等级、责任单位；')\ndoc.add_paragraph('3. 消缺实施：制定处理方案，组织实施；')\ndoc.add_paragraph('4. 验收闭环：消缺完成后验收，记录归档。')\n\n# ============ 第七章 ============\ndoc.add_heading('第七章  沉降观测专项方案', level=1)\n\ndoc.add_heading('一、观测对象', level=2)\ndoc.add_paragraph('1. 13台风机基础；')\ndoc.add_paragraph('2. 220kV升压站主变及GIS设备基础；')\ndoc.add_paragraph('3. 综合楼、配电室等建（构）筑物；')\ndoc.add_paragraph('4. 4基铁塔基础。')\n\ndoc.add_heading('二、观测点布设', level=2)\ndoc.add_paragraph('1. 每台风机基础布设4个观测点（基础四角）；')\ndoc.add_paragraph('2. 升压站主要设备基础每处布设2-4个观测点；')\ndoc.add_paragraph('3. 观测点采用不锈钢观测标，进行统一编号。')\n\ndoc.add_heading('三、观测频率', level=2)\ndoc.add_paragraph('1. 复工后立即进行一次全面观测，作为基准值；')\ndoc.add_paragraph('2. 施工期间每月观测一次；')\ndoc.add_paragraph('3. 全部投运后第一年每季度观测一次；')\ndoc.add_paragraph('4. 特殊情况（大雨、地震后）增加观测频次。')\n\ndoc.add_heading('四、预警标准', level=2)\ndoc.add_paragraph('1. 日沉降量＞2mm或累计沉降量＞30mm时预警；')\ndoc.add_paragraph('2. 基础倾斜率＞3‰时预警；')\ndoc.add_paragraph('3. 出现不均匀沉降时立即报告并采取处理措施。')\n\n# ============ 第八章 ============\ndoc.add_heading('第八章  环境保护与水保恢复方案', level=1)\n\ndoc.add_heading('一、风机平台整治', level=2)\ndoc.add_paragraph('1. 施工垃圾清理：彻底清理平台内的包装材料、废料、油污；')\ndoc.add_paragraph('2. 平面修整：平整场地，修整边坡至设计坡度；')\ndoc.add_paragraph('3. 排水系统：完善平台排水沟槽，确保雨水有序排放。')\n\ndoc.add_heading('二、水保恢复措施', level=2)\ndoc.add_paragraph('1. 边坡防护：采用生态袋、格构护坡等方式加固；')\ndoc.add_paragraph('2. 植被恢复：撒播本地草籽，种植适应性灌木；')\ndoc.add_paragraph('3. 临时措施：施工期间铺设密目网，防止水土流失；')\ndoc.add_paragraph('4. 季节性措施：针对东北地区冻融特点，春季加强坡面检查。')\n\ndoc.add_heading('三、扬尘控制', level=2)\ndoc.add_paragraph('1. 施工道路定期洒水降尘；')\ndoc.add_paragraph('2. 裸露土方覆盖防尘网；')\ndoc.add_paragraph('3. 运输车辆覆盖篷布。')\n\ndoc.add_heading('四、固体废物管理', level=2)\ndoc.add_paragraph('1. 分类收集可回收和不可回收废物；')\ndoc.add_paragraph('2. 危险废物（废油、废电池）单独存放，委托有资质单位处理；')\ndoc.add_paragraph('3. 生活垃圾定点收集，定期清运。')\n\n# ============ 第九章 ============\ndoc.add_heading('第九章  环保应急预案', level=1)\n\ndoc.add_heading('一、应急组织', level=2)\ndoc.add_paragraph('成立环保应急小组，组长为项目副经理，成员包括安全员、各施工班组负责人。')\n\ndoc.add_heading('二、风险识别与防控措施', level=2)\n\ntable = doc.add_table(rows=5, cols=4)\ntable.style = 'Table Grid'\nheader = table.rows[0].cells\nheader[0].text = '风险类型'\nheader[1].text = '重点区域'\nheader[2].text = '预防措施'\nheader[3].text = '应急物资'\n\ndata = [\n    ['油品泄露', '升压站事故油池、箱变底部、机舱平台', '加装集油盘、定期检查储油容器', '吸油毡、围油栏、集油桶'],\n    ['水土流失', '风机平台边坡、施工道路', '完善排水、铺设防护网', '沙袋、土工布'],\n    ['植被破坏', '施工临时占地', '施工围挡、表土剥离保护', '草籽、营养土'],\n    ['扬尘污染', '施工道路、裸露土方', '洒水降尘、覆盖防尘网', '洒水车、防尘网'],\n]\n\nfor i, row_data in enumerate(data, 1):\n    cells = table.rows[i].cells\n    for j, val in enumerate(row_data):\n        cells[j].text = val\n\ndoc.add_heading('三、应急响应程序', level=2)\ndoc.add_paragraph('1. 发现险情 → 立即停止作业 → 报告应急小组；')\ndoc.add_paragraph('2. 启动应急预案 → 调配应急物资 → 组织应急处置；')\ndoc.add_paragraph('3. 控制事态发展 → 减轻环境影响 → 记录处置过程；')\ndoc.add_paragraph('4. 事后评估 → 总结经验 → 完善预防措施。')\n\ndoc.add_heading('四、社会监督', level=2)\ndoc.add_paragraph('1. 在施工现场设置环保公示牌，公布举报电话；')\ndoc.add_paragraph('2. 主动接受建设单位、当地环保部门监督；')\ndoc.add_paragraph('3. 关注周边村庄水源、林地影响，及时回应关切。')\n\n# ============ 第十章 ============\ndoc.add_heading('第十章  复工验收程序', level=1)\n\ndoc.add_heading('一、复工自查', level=2)\ndoc.add_paragraph('1. 组织复工条件全面检查；')\ndoc.add_paragraph('2. 整改发现的安全隐患；')\ndoc.add_paragraph('3. 形成复工自查报告。')\n\ndoc.add_heading('二、复工申请', level=2)\ndoc.add_paragraph('1. 向监理单位提交复工申请表；')\ndoc.add_paragraph('2. 附复工自查报告及相关证明材料；')\ndoc.add_paragraph('3. 监理单位组织现场核查。')\n\ndoc.add_heading('三、复工批准', level=2)\ndoc.add_paragraph('1. 监理单位核查合格后签署意见；')\ndoc.add_paragraph('2. 建设单位审批同意；')\ndoc.add_paragraph('3. 正式复工，按计划推进各项工作。')\n\ndoc.add_page_break()\n\n# ============ 附件表格 ============\ndoc.add_heading('附件1  剩余工程复工进度计划表', level=1)\n\ntable = doc.add_table(rows=8, cols=7)\ntable.style = 'Table Grid'\nheader = table.rows[0].cells\nheader[0].text = '序号'\nheader[1].text = '任务名称'\nheader[2].text = '具体工作内容'\nheader[3].text = '计划开始'\nheader[4].text = '计划完成'\nheader[5].text = '责任人'\nheader[6].text = '备注'\n\ndata = [\n    ['1', '铁塔施工', '4基35kV铁塔组立及架线', '3月5日', '3月15日', '线路负责人', '邻近