置',\n    '  第七章  安全保障措施',\n    '  第八章  质量保障措施',\n    '  第九章  应急管理',\n    '  第十章  复工验收程序',\n    '第二部分  风机调试计划',\n    '第三部分  电装进度计划表',\n    '第四部分  相关管理表格'\n]\n\nfor item in toc_items:\n    p = doc.add_paragraph()\n    p.paragraph_format.left_indent = Inches(0.25 if item.startswith('  ') else 0)\n    p.add_run(item)\n\ndoc.add_page_break()\n\n# ============ 第一部分 ============\ndoc.add_heading('第一部分  复工复产专项方案', level=1)\n\n# ========== 第一章 ==========\ndoc.add_heading('第一章  工程概况', level=2)\ndoc.add_heading('一、项目基本情况', level=3)\n\np = doc.add_paragraph()\np.add_run('项目名称：').bold = True\np.add_run('神池县磨石山、义井100MW风电项目（二期）\\n')\np.add_run('建设地点：').bold = True\np.add_run('山西省忻州市神池县\\n')\np.add_run('建设单位：').bold = True\np.add_run('XXX新能源有限公司\\n')\np.add_run('总承包单位（EPC）：').bold = True\np.add_run('山西晋开电力科技有限公司\\n')\np.add_run('监理单位：').bold = True\np.add_run('XXX工程监理有限公司\\n')\n\ndoc.add_heading('二、工程规模及建设内容', level=3)\ndoc.add_paragraph('本期工程装机容量100MW，安装20台单机容量5.0MW的风力发电机组，配套建设110kV升压站1座，集电线路35km。')\n\ndoc.add_heading('三、当前工程进展情况', level=3)\ndoc.add_paragraph('本项目于2024年5月开工建设，截至目前已完成以下工作：')\ndoc.add_paragraph('1. 风机基础：20台风机基础全部完成；')\ndoc.add_paragraph('2. 风机吊装：20台塔筒、机舱、叶片吊装全部完成；')\ndoc.add_paragraph('3. 升压站：土建工程完成，电气设备安装完成，并网投产；')\ndoc.add_paragraph('4. 集电线路：地埋敷设完成；')\ndoc.add_paragraph('5. 已投产风机：8台风机已完成调试并发电，运行正常。')\n\ndoc.add_heading('四、剩余工作内容', level=3)\ndoc.add_paragraph('1. 风机电气安装：12台未调试风机（F09-F20）的电气接线及检查；')\ndoc.add_paragraph('2. 风机调试：12台风机的静态调试、动态调试及并网调试；')\ndoc.add_paragraph('3. 全场联调：全场风机联合运行调试；')\ndoc.add_paragraph('4. 竣工资料：竣工图纸、资料的整理归档。')\n\ndoc.add_heading('五、春节停工情况', level=3)\ndoc.add_paragraph('本项目于2025年1月20日进入春节假期停工，停工期间安排了值班人员进行现场看护，设备及设施封存完好，未发生安全事件。')\n\n# ========== 第二章 ==========\ndoc.add_heading('第二章  编制依据', level=2)\ndoc.add_heading('一、法律法规', level=3)\ndoc.add_paragraph('1. 《中华人民共和国安全生产法》（2021年修订版）')\ndoc.add_paragraph('2. 《建设工程安全生产管理条例》（国务院令第393号）')\ndoc.add_paragraph('3. 《电力建设工程施工安全监督管理办法》（发改委令第28号）')\n\ndoc.add_heading('二、标准规范', level=3)\ndoc.add_paragraph('1. 《风力发电工程施工与验收规范》（GB/T 5XXXX-20XX）')\ndoc.add_paragraph('2. 《电力建设安全工作规程 第2部分：电力线路》（DL 5009.2）')\ndoc.add_paragraph('3. 《电力建设安全工作规程 第3部分：变电站》（DL 5009.3）')\ndoc.add_paragraph('4. 《建筑施工高处作业安全技术规范》（JGJ 80-2016）')\ndoc.add_paragraph('5. 《施工现场临时用电安全技术规范》（JGJ 46-2005）')\n\ndoc.add_heading('三、项目文件', level=3)\ndoc.add_paragraph('1. EPC总承包合同及招投标文件')\ndoc.add_paragraph('2. 施工组织设计及专项施工方案')\ndoc.add_paragraph('3. 风机厂家技术说明书及调试手册')\ndoc.add_paragraph('4. 设计图纸、变更单及技术交底文件')\n\n# ========== 第三章 ==========\ndoc.add_heading('第三章  复工准备', level=2)\ndoc.add_heading('一、人员准备', level=3)\ndoc.add_paragraph('1. 项目管理人员（项目经理、技术负责人、安全员等）按时到岗履职；')\ndoc.add_paragraph('2. 组织施工班组人员返场，进行人员实名制登记；')\ndoc.add_paragraph('3. 特种作业人员（电工、焊工、起重工、高处作业人员等）持证上岗；')\ndoc.add_paragraph('4. 对全体返场人员进行复工安全教育培训并考核合格。')\n\ndoc.add_heading('二、技术准备', level=3)\ndoc.add_paragraph('1. 复工前组织图纸会审，核对设计与现场实际情况；')\ndoc.add_paragraph('2. 编制专项施工方案（调试方案、电气安装方案）并报审；')\ndoc.add_paragraph('3. 对施工班组进行详细的技术交底和安全交底；')\ndoc.add_paragraph('4. 检查施工机械设备的技术状况，确保完好。')\n\ndoc.add_heading('三、现场准备', level=3)\ndoc.add_paragraph('1. 对施工现场进行全面安全检查，消除安全隐患；')\ndoc.add_paragraph('2. 检查临时用电设施，确保用电安全；')\ndoc.add_paragraph('3. 检查脚手架、吊篮等设施的安全性能；')\ndoc.add_paragraph('4. 清理现场积雪、积冰，确保作业面安全；')\ndoc.add_paragraph('5. 检查消防设施配置情况。')\n\ndoc.add_heading('四、物资准备', level=3)\ndoc.add_paragraph('1. 盘点剩余工程材料，制定材料采购计划；')\ndoc.add_paragraph('2. 检查安全防护用品的库存及质量；')\ndoc.add_paragraph('3. 准备应急物资及救援设备。')\n\n# ========== 第四章 ==========\ndoc.add_heading('第四章  组织机构', level=2)\ndoc.add_heading('一、复工领导小组', level=3)\n\ntable = doc.add_table(rows=8, cols=3)\ntable.style = 'Table Grid'\nheader = table.rows[0].cells\nheader[0].text = '职务'\nheader[1].text = '姓名'\nheader[2].text = '职责'\n\ndata = [\n    ['组长', 'XXX', '全面负责复工工作，审批复工计划'],\n    ['副组长', 'XXX', '负责技术管理、方案编制'],\n    ['副组长', 'XXX', '负责安全管理、教育培训'],\n    ['成员', 'XXX', '负责施工组织、进度控制'],\n    ['成员', 'XXX', '负责质量检查、验收工作'],\n    ['成员', 'XXX', '负责设备管理、调试工作'],\n    ['成员', 'XXX', '负责物资保障、材料供应'],\n]\n\nfor i, row_data in enumerate(data, 1):\n    cells = table.rows[i].cells\n    for j, val in enumerate(row_data):\n        cells[j].text = val\n\ndoc.add_heading('二、职责分工', level=3)\ndoc.add_paragraph('1. 组长：全面负责复工复产工作，审批复工计划；')\ndoc.add_paragraph('2. 技术负责人：负责技术交底、方案编制、技术指导；')\ndoc.add_paragraph('3. 安全负责人：负责安全检查、教育培训、隐患整改；')\ndoc.add_paragraph('4. 施工负责人：负责现场施工组织、进度控制；')\ndoc.add_paragraph('5. 质量负责人：负责质量检查、验收工作。')\n\ndoc.add_heading('三、工作专班', level=3)\ndoc.add_paragraph('1. 电气安装专班：负责剩余12台风机电气安装工作；')\ndoc.add_paragraph('2. 调试工作专班：负责风机静态、动态及并网调试；')\ndoc.add_paragraph('3. 安全监督专班：负责现场安全监督检查；')\ndoc.add_paragraph('4. 质量检查专班：负责工序质量检查验收。')\n\n# ========== 第五章 ==========\ndoc.add_heading('第五章  复工计划', level=2)\ndoc.add_heading('一、复工时间节点', level=3)\n\ntable = doc.add_table(rows=5, cols=2)\ntable.style = 'Table Grid'\ndata = [\n    ['管理人员到岗', '2026年2月20日'],\n    ['施工人员进场', '2026年2月25日'],\n    ['复工安全检查', '2026年2月26日-2月28日'],\n    ['正式复工', '2026年3月3日'],\n]\n\nfor i, row_data in enumerate(data):\n    cells = table.rows[i].cells\n    for j, val in enumerate(row_data):\n        cells[j].text = val\n\ndoc.add_heading('二、复工初期工作安排', level=3)\ndoc.add_paragraph('（一）复工第一周（3月3日-3月9日）')\ndoc.add_paragraph('1. 组织全员复工安全教育培训；')\ndoc.add_paragraph('2. 完成现场全面安全检查及隐患整改；')\ndoc.add_paragraph('3. F09、F10风机电气安装；')\ndoc.add_paragraph('4. 集电线路巡检及消缺。')\n\ndoc.add_paragraph('\\n（二）复工第二周（3月10日-3月16日）')\ndoc.add_paragraph('1. F11、F12风机电气安装；')\ndoc.add_paragraph('2. F09-F10风机静态调试；')\ndoc.add_paragraph('3. 电缆终端头制作安装。')\n\ndoc.add_paragraph('\\n（三）复工第三周（3月17日-3月23日）')\ndoc.add_paragraph('1. F13、F14风机电气安装；')\ndoc.add_paragraph('2. F11-F12风机静态调试；')\ndoc.add_paragraph('3. F09、F10风机动态调试及并网。')\n\ndoc.add_heading('三、总体进度目标', level=3)\ntable = doc.add_table(rows=5, cols=2)\ntable.style = 'Table Grid'\ndata = [\n    ['3月15日前', '完成F09-F12风机电气安装'],\n    ['3月31日前', '完成F09-F20风机电气安装'],\n    ['4月15日前', '完成剩余12台风机调试并网'],\n    ['4月30日前', '完成全场联调及专项验收准备'],\n]\n\nfor i, row_data in enumerate(data):\n    cells = table.rows[i].cells\n    for j, val in enumerate(ro